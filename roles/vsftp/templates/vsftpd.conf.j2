# Core Operational Settings
anonymous_enable=NO
local_enable=YES
write_enable=YES
local_umask=022
dirmessage_enable=YES
xferlog_enable=YES
connect_from_port_20=YES
xferlog_std_format=YES

# Forcing VSFTPD to run in standalone mode and listen on IPv4 only
listen=YES
listen_ipv6=NO
pam_service_name=vsftpd

# Security Chroot Jail Environment
chroot_local_user=YES
allow_writeable_chroot=YES

# System Access Controls
userlist_enable=YES
userlist_file=/etc/vsftpd/user_list
userlist_deny=NO

# Explicit SSL/TLS Configuration
ssl_enable=YES
allow_anon_ssl=NO
force_local_data_ssl=YES
force_local_logins_ssl=YES
ssl_tlsv1_2=YES
ssl_tlsv1_3=YES
ssl_ciphers=HIGH
rsa_cert_file=/etc/pki/tls/certs/vsftpd.crt
rsa_private_key_file=/etc/pki/tls/private/vsftpd.key
require_ssl_reuse=NO

# Passive Port Redirection Range dynamically allocated for FTP clients to connect to the server
pasv_enable=YES
pasv_min_port= {{ ftp_port_ranges.split('-')[0] }}
pasv_max_port= {{ ftp_port_ranges.split('-')[1].split('/')[0] }} 

# Production Logging Configuration
xferlog_enable=YES
xferlog_std_format=NO
log_ftp_protocol=YES
vsftpd_log_file=/var/log/vsftpd.log