[req]
default_bits       = 2048
default_md         = sha256
distinguished_name = dn
x509_extensions    = v3_req
prompt             = no

[dn]
C            = IN
ST           = West Bengal
L            = Kolkata
O            = My Company Inc
OU           = IT Department
CN           = localhost

[v3_req]
keyUsage           = digitalSignature, keyEncipherment
extendedKeyUsage   = serverAuth
subjectAltName     = @alt_names

[alt_names]
DNS.1              = localhost
DNS.2              = *.localhost
DNS.3              = {{ ansible_facts['fqdn'] }}
IP.1               = 127.0.0.1
IP.2               = {{ ansible_facts['default_ipv4']['address'] }}
