user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log notice;
pid /run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for"';

    access_log  /var/log/nginx/access_log main;

    include             /etc/nginx/mime.types;
    default_type        application/octet-stream;
    sendfile            on;
    tcp_nopush          on;
    keepalive_timeout   65;
    types_hash_max_size 4096;

    server {
        # Listens on port 8080 to prevent collision with Apache on 80/443
        listen       8080 default_server;
        listen       [::]:8080 default_server;
        server_name  _;
        
        # Dedicated isolated web root directory
        root         /var/www/nginx;
        index        index.php index.html index.htm;

        location / {
            try_files $uri $uri/ =404;
        }

        # Route PHP files to the PHP-FPM Unix Socket
        location ~ \.php$ {
            try_files $uri =404;
            fastcgi_intercept_errors on;
            include fastcgi_params;
            
            # Points directly to the dedicated socket file
            fastcgi_pass unix:/run/php-fpm/nginx-php.sock;
            fastcgi_index index.php;
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        }

        # Deny access to hidden configuration files (like .htaccess)
        location ~ /\.ht {
            deny all;
        }
    }
}
